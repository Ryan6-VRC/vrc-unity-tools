# This repo holds UPM packages only (no Unity project). Keep .meta files tracked —
# Unity generates them on first import and they carry stable asset GUIDs.

# OS / editor junk
.DS_Store
Thumbs.db
desktop.ini
.vs/
.idea/
.vscode/

# git worktrees for isolated feature work
.worktrees/

# worktree-local headless test editor (generated by tools/setup-test-editor.ps1 -Dest ./TestEditor
# to avoid contending for the shared Atelier/TestEditor when sessions run concurrently)
/TestEditor/
